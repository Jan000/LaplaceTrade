# Copy to .env (standalone) or paste these into Coolify's Environment Variables panel.
# Every CT_* var maps to the nested config (delimiter __); env overrides config.yaml.
# Leave blank to keep paper-only / no-auth / no-alerts.

# --- Exchange API keys (real trading; create a key with TRADE but NOT WITHDRAW) ---
CT_EXCHANGE__API_KEY=
CT_EXCHANGE__API_SECRET=
# Dry-run the real-order path safely on the exchange testnet first:
CT_EXCHANGE__TESTNET=false

# --- Dashboard login (Basic-auth). Set a password to require login before exposing it ---
CT_DASHBOARD__AUTH_USER=admin
CT_DASHBOARD__AUTH_PASSWORD=

# --- Alerts (halts / trades / daily summary) ---
CT_NOTIFY__WEBHOOK_URL=
CT_NOTIFY__TELEGRAM_BOT_TOKEN=
CT_NOTIFY__TELEGRAM_CHAT_ID=

# --- Optional: circuit breakers (real-money safety) ---
# CT_RISK__MAX_DAILY_LOSS_PCT=0.05
# CT_RISK__MAX_DRAWDOWN_PCT=0.10
